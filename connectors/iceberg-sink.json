{
  "name": "iceberg-sink-connector",
  "config": {
    "connector.class": "org.apache.iceberg.connect.IcebergSinkConnector",
    "tasks.max": "4",

    "topics": "cdc.public.zones,cdc.public.vehicle_types,cdc.public.drivers,cdc.public.passengers,cdc.public.rides,cdc.ride_ops_mg.ride_events,cdc.ride_ops_mg.driver_location_stream",

    "iceberg.catalog.type": "jdbc",
    "iceberg.catalog.jdbc.uri": "jdbc:postgresql://postgres-catalog:5432/iceberg_catalog",
    "iceberg.catalog.jdbc.user": "iceberg",
    "iceberg.catalog.jdbc.password": "iceberg",
    "iceberg.catalog.warehouse": "s3://iceberg-warehouse/",
    "iceberg.catalog.io-impl": "org.apache.iceberg.aws.s3.S3FileIO",
    "iceberg.catalog.s3.endpoint": "http://minio:9000",
    "iceberg.catalog.s3.access-key-id": "minioadmin",
    "iceberg.catalog.s3.secret-access-key": "minioadmin",
    "iceberg.catalog.s3.path-style-access": "true",
    "iceberg.catalog.s3.region": "us",

    "iceberg.tables.auto-create-enabled": "true",
    "iceberg.tables.evolve-schema-enabled": "true",
    "iceberg.tables.upsert-mode-enabled": "true",
    "iceberg.tables.cdc-field": "__op",

    "iceberg.tables.route-field": "_source_system",

    "iceberg.table.cdc.public.zones":                       "cdc.zones",
    "iceberg.table.cdc.public.vehicle_types":               "cdc.vehicle_types",
    "iceberg.table.cdc.public.drivers":                     "cdc.drivers",
    "iceberg.table.cdc.public.passengers":                  "cdc.passengers",
    "iceberg.table.cdc.public.rides":                       "cdc.rides",
    "iceberg.table.cdc.ride_ops_mg.ride_events":            "cdc.ride_events",
    "iceberg.table.cdc.ride_ops_mg.driver_location_stream": "cdc.driver_location_stream",

    "iceberg.control.commit.interval-ms": "1800000",
    "iceberg.control.commit.timeout-ms": "300000",

    "iceberg.tables.write-format": "PARQUET",
    "iceberg.tables.parquet.compression": "SNAPPY",

    "key.converter": "io.confluent.connect.avro.AvroConverter",
    "key.converter.schema.registry.url": "http://schema-registry:8081",
    "value.converter": "io.confluent.connect.avro.AvroConverter",
    "value.converter.schema.registry.url": "http://schema-registry:8081",

    "errors.tolerance": "none",
    "errors.log.enable": "true",
    "errors.log.include.messages": "true"
  }
}